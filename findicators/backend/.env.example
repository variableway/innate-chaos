# HyperLiquid
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz

# FRED
FRED_API_KEY=your_fred_api_key_here

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/findicators

# Scheduler
CRYPTO_FETCH_INTERVAL_SECONDS=300
ECONOMIC_FETCH_INTERVAL_SECONDS=86400

# Signal Engine
OIL_TREND_DAYS=7
GOLD_TREND_DAYS=7
BTC_MOMENTUM_DAYS=7
VOLATILITY_WINDOW=20
RISK_ON_THRESHOLD=0.6
RISK_OFF_THRESHOLD=0.4
