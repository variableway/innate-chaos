# HyperTrace Backend Configuration

# Database - TimescaleDB
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://hypertrace:hypertrace_secret@localhost:5432/hypertrace

# For development with SQLite (not recommended for production):
# DATABASE_URL=sqlite+aiosqlite:///./hypertrace.db

# API Keys
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
COINGECKO_API_KEY=your_coingecko_api_key_here  # Optional, but recommended for higher rate limits

# Application Settings
APP_NAME=HyperTrace
DEBUG=false
LOG_LEVEL=INFO

# Scheduler
FETCH_INTERVAL_MINUTES=5

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Security
SECRET_KEY=your-secret-key-here-change-in-production
